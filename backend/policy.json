{"Version":"2012-10-17","Statement":[
  {"Effect":"Allow","Action":["logs:CreateLogGroup","logs:CreateLogStream","logs:PutLogEvents"],"Resource":"*"},
  {"Effect":"Allow","Action":["dynamodb:GetItem","dynamodb:PutItem","dynamodb:UpdateItem","dynamodb:Query","dynamodb:Scan","dynamodb:DeleteItem"],
   "Resource":[
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_users",
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_feed",
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_group",
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_dm",
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_canvas",
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_donations",
     "arn:aws:dynamodb:us-east-1:<AWS_ACCOUNT_ID>:table/camel_scores"
   ]},
  {"Effect":"Allow","Action":["s3:PutObject"],
   "Resource":[
     "arn:aws:s3:::<S3_BUCKET>/cabal-uploads/*"
   ]}
]}
